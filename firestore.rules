rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isParticipant(convId) {
      return isAuth() && 
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
    }

    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    match /usernames/{username} {
      allow read: if isAuth();
      allow create: if isOwner(request.resource.data.uid);
      allow delete: if isOwner(resource.data.uid);
      allow update: if false;
    }

    match /conversations/{convId} {
      allow read: if isParticipant(convId);
      allow create: if isAuth() && 
        request.auth.uid in request.resource.data.participants && 
        request.resource.data.participants.size() == 2;
      allow update: if isParticipant(convId);
      allow delete: if false;

      match /messages/{msgId} {
        allow read: if isParticipant(convId);
        allow create: if isParticipant(convId) && 
          request.resource.data.senderId == request.auth.uid;
        allow update: if isParticipant(convId);
        allow delete: if false;
      }
    }

    match /rateLimits/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /reports/{reportId} {
      allow create: if isAuth() && 
        request.resource.data.reporterId == request.auth.uid;
      allow read: if false;
      allow update, delete: if false;
    }
  }
}
